# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase recommended)
DATABASE_URL=postgresql://user:password@host:6543/postgres

# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Backend / Deployment ─────────────────────────────────────────────────────
# Set in GitHub Actions secrets so the frontend build bakes in the backend URL
# Leave empty for local dev (frontend proxies to localhost:5000 automatically)
VITE_API_URL=https://styleai-backend.onrender.com
# Set on Render to allow GitHub Pages CORS requests
FRONTEND_URL=https://aya1m22.github.io

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
OAUTH_SERVER_URL=http://localhost:5000
# Email that gets admin role on first sign-in
OWNER_OPEN_ID=your@email.com

# ─── Gemini API (required for AI Stylist photo analysis) ─────────────────────
# Backend uses GEMINI_API_KEY; falls back to VITE_GEMINI_API_KEY if not set.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Frontend uses VITE_GEMINI_API_KEY for the Occasion Advisor chat.
VITE_GEMINI_API_KEY=your_gemini_api_key

# ─── Stripe (required for real payments) ─────────────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
# Use sk_test_... keys for testing, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ─── SMTP Email (required for invoice emails after payment) ───────────────────
# Gmail example: enable 2FA → create an App Password at myaccount.google.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="StyleAI <your-gmail@gmail.com>"

# ─── Optional (not required unless using Manus / Forge LLM) ──────────────────
# BUILT_IN_FORGE_API_KEY=
# BUILT_IN_FORGE_API_URL=
