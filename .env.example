# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase recommended)
DATABASE_URL=postgresql://user:password@host:6543/postgres

# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
OAUTH_SERVER_URL=http://localhost:5000
# Email that gets admin role on first sign-in
OWNER_OPEN_ID=your@email.com

# ─── Gemini API (required for AI Stylist photo analysis) ─────────────────────
# Backend uses GEMINI_API_KEY; falls back to VITE_GEMINI_API_KEY if not set.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Frontend uses VITE_GEMINI_API_KEY for the Occasion Advisor chat.
VITE_GEMINI_API_KEY=your_gemini_api_key

# ─── Optional (not required unless using Manus / Forge LLM) ──────────────────
# BUILT_IN_FORGE_API_KEY=
# BUILT_IN_FORGE_API_URL=
