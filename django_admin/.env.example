# Django Admin Dashboard — Environment Variables
# Copy this file to .env and fill in your values

# Django secret key (change this in production!)
DJANGO_SECRET_KEY=django-insecure-change-this-in-production

# Set to False in production
DEBUG=True

# Database URL — same as your Node.js backend
# Format: mysql://username:password@host:port/database_name
DATABASE_URL=mysql://username:password@localhost:3306/fashion_shop

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1
